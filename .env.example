# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (optional). If set, only this user may use the
# bot; everyone else gets "Access denied." Leave empty to allow anyone (dev).
ALLOWED_TELEGRAM_USER_ID=

# AI provider (optional). If both are empty, the bot uses built-in fallback rules.
# Prefer ANTHROPIC_API_KEY (Claude). OPENAI_API_KEY is also supported.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
ANTHROPIC_MODEL=
OPENAI_MODEL=
